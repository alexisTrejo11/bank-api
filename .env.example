# Copy to `.env` in the repository root (`cp .env.example .env`) before `docker compose up`.
# For default in-memory H2 (no Postgres), omit SPRING_DATASOURCE_* here or comment them out.
# Never commit real secrets.
# Spring Boot reads the same keys via environment; a `.env` file is loaded by DotEnvEnvironmentPostProcessor
# (lowest precedence — OS env vars override file values). Docker Compose also reads `.env` for substitution.

# --- PostgreSQL (container + Spring profiles: postgres, docker) ---
POSTGRES_DB=at_bank
POSTGRES_USER=bank
# Required for `docker compose up` (postgres service).
POSTGRES_PASSWORD=change-me-local-only
POSTGRES_PORT=5432

# Spring datasource (required for `postgres` and `docker` profiles — no defaults for password in YAML)
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/at_bank
SPRING_DATASOURCE_USERNAME=bank
SPRING_DATASOURCE_PASSWORD=change-me-local-only

# When running the app with profile `docker` inside Compose network, use e.g.:
# SPRING_DATASOURCE_URL=jdbc:postgresql://postgres:5432/at_bank
# SPRING_DATASOURCE_USERNAME=bank
# SPRING_DATASOURCE_PASSWORD=same-as-POSTGRES_PASSWORD

# --- Redis ---
SPRING_DATA_REDIS_HOST=localhost
SPRING_DATA_REDIS_PORT=6379
# Leave empty if no ACL password
SPRING_DATA_REDIS_PASSWORD=

# --- Kafka (docker / Redpanda) ---
SPRING_KAFKA_BOOTSTRAP_SERVERS=localhost:19092
SPRING_KAFKA_CONSUMER_GROUP_ID=bank-notifications

# --- JWT signing (production / stable dev — PKCS#8 private + SPKI public PEM, include headers) ---
# BANK_SECURITY_JWT_PRIVATE_KEY_PEM=-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----
# BANK_SECURITY_JWT_PUBLIC_KEY_PEM=-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----

# --- Optional domain toggles ---
BANK_LOANS_INTERNAL_FUNDING_ACCOUNT_ID=aaaaaaaa-aaaa-aaaa-aaaa-aaaaaaaaaaaa
BANK_NOTIFICATIONS_DEV_REDIRECT_EMAIL=
BANK_NOTIFICATIONS_STUB_SMS_E164=+15555550100
BANK_NOTIFICATIONS_KAFKA_DISPATCH_TOPIC=bank.notifications.dispatch
BANK_NOTIFICATIONS_KAFKA_PIPELINE_TOPIC=bank.notifications.pipeline

# --- Dotenv ---
# Optional: directory containing `.env` if not the process working directory
# BANK_DOTENV_PATH=/path/to/repo

# --- Full Docker Compose stack (see docs/v.0.3.0/DOCKER.md) ---
# Compose overrides JDBC/Redis/Kafka for in-network hostnames; keep POSTGRES_* in sync.
# BANK_KAFKA_ENABLED=false
# GRAFANA_ADMIN_USER=admin
# GRAFANA_ADMIN_PASSWORD=admin
# NGINX_HTTP_PORT=80
# KIBANA_PORT=5601
# PROMETHEUS_PORT=9090
# GRAFANA_PORT=3000
# BANK_API_IMAGE_TAG=local
