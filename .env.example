# Copy to .env and adjust (Compose can use env_file; Spring reads the environment).
# Do not commit real secrets.

# PostgreSQL (optional override when not using application-postgres defaults)
BANK_DATASOURCE_URL=jdbc:postgresql://localhost:5432/at_bank
BANK_DATASOURCE_USERNAME=bank
BANK_DATASOURCE_PASSWORD=bank

# Redis (IAM refresh/blocklist, payment idempotency when enabled)
SPRING_DATA_REDIS_HOST=localhost
SPRING_DATA_REDIS_PORT=6379

# Kafka (Redpanda external listener from docker-compose)
SPRING_KAFKA_BOOTSTRAP_SERVERS=localhost:19092

# JWT keys (production): PEM or base64 — never commit real values
# BANK_JWT_PRIVATE_KEY=
# BANK_JWT_PUBLIC_KEY=
